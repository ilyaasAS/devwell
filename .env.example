# Copy this file to .env.local and fill in real values.
# Required for: Symfony app, Docker Compose, Stripe, Gemini, DB, health check.

# --- Symfony ---
APP_ENV=dev
APP_SECRET=change-me
APP_DEBUG=1
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR

# --- Database (MySQL/MariaDB) ---
DATABASE_URL="mysql://app:!ChangeMe!@database:3306/devwell?serverVersion=10.11.2-MariaDB&charset=utf8mb4"

# --- Docker Compose (DB container) ---
DB_USER=app
DB_PASSWORD=!ChangeMe!
DB_NAME=devwell
DB_ROOT_PASSWORD=root

# --- Mailer ---
MAILER_DSN="smtp://mailpit:1025"

# --- Stripe ---
STRIPE_PUBLIC_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# --- MongoDB ---
MONGODB_URL="mongodb://mongodb:27017"
MONGODB_DB=devwell

# --- Google Gemini API ---
GOOGLE_GEMINI_API_KEY=

# --- Health check (API / monitoring) ---
HEALTH_CHECK_TOKEN=change-me
